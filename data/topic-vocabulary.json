{
  "_meta": {
    "schemaVersion": 2,
    "description": "Supplemental known-value sets for topic fields. Field names are sourced from EdogQaLlmClient.TopicFieldRegistry (the canonical source of truth). This file adds value enumeration for eval scoring and prompt enrichment. Legacy telemetry.* entries retained for backward compatibility with older scenarios.",
    "owner": "edog-qa"
  },
  "topics": {
    "http.statusCode": {
      "type": "integer",
      "knownValues": [200, 201, 202, 204, 301, 302, 304, 400, 401, 403, 404, 409, 422, 429, 500, 502, 503, 504]
    },
    "http.method": {
      "type": "string",
      "knownValues": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
    },
    "token.scheme": {
      "type": "string",
      "knownValues": ["obo", "legacy", "DirectAAD", "WSPL"]
    },
    "token.tokenType": {
      "type": "string",
      "knownValues": ["Bearer", "MWC", "S2S"]
    },
    "log.level": {
      "type": "string",
      "knownValues": ["Trace", "Debug", "Information", "Warning", "Error", "Critical"]
    },
    "log.authMode": {
      "type": "string",
      "knownValues": ["OBO", "DirectAAD", "WSPL"]
    },
    "flag.result": {
      "type": "string",
      "knownValues": ["true", "false", "on", "off"]
    },
    "retry.reason": {
      "type": "string",
      "knownValues": ["Throttle", "Transient", "ServerError", "Timeout"]
    },
    "di.lifetime": {
      "type": "string",
      "knownValues": ["Singleton", "Scoped", "Transient"]
    },
    "cache.operation": {
      "type": "string",
      "knownValues": ["Get", "Set", "Remove", "Expire"]
    },
    "telemetry.auth.scheme": {
      "type": "string",
      "knownValues": ["obo", "legacy", "DirectAAD", "WSPL"],
      "_legacy": true
    },
    "telemetry.auth.failureReason": {
      "type": "string",
      "knownValues": ["OboTokenExpired", "OboClaimsMissing", "OboProviderError", "TokenExtractionFailed", "WSPLUnavailable", "DirectAADRejected"],
      "_legacy": true
    },
    "telemetry.obo.tokenAcquired": {
      "type": "boolean",
      "knownValues": [true, false],
      "_legacy": true
    },
    "telemetry.obo.cacheHit": {
      "type": "boolean",
      "knownValues": [true, false],
      "_legacy": true
    },
    "telemetry.sqlEndpoint.connectionEstablished": {
      "type": "boolean",
      "knownValues": [true, false],
      "_legacy": true
    },
    "telemetry.insights.queryKind": {
      "type": "string",
      "knownValues": ["summary", "table", "dataQualityReport"],
      "_legacy": true
    },
    "telemetry.flag.evaluated": {
      "type": "boolean",
      "knownValues": [true, false],
      "_legacy": true
    },
    "telemetry.flag.value": {
      "type": "string",
      "knownValues": ["true", "false", "on", "off"],
      "_legacy": true
    }
  }
}
