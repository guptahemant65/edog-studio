+        private void UpdateOrDeleteTokenInTokenManager(string tenantId, Guid artifactId, Guid iterationId, string mwcToken, DagExecutionStatus status)
+        {
+            // TODO this feature flight is just a defensive mechanism. To be removed ASAP once we have confidence of running this in prod for few days
+            if (featureFlighter.IsEnabled(FeatureNames.FLTTokenManagerSkipClearOnDagCompletion, Guid.TryParse(tenantId, out var tenantGuid) ? tenantGuid : null, null, null))
+            {
+                Tracer.LogSanitizedVerbose($"Feature flag {FeatureNames.FLTTokenManagerSkipClearOnDagCompletion} is enabled.");
+                try
+                {
+                    tokenManager.UpdateCachedToken(artifactId, iterationId, mwcToken);
+                }
+                catch (Exception e)
+                {
+                    Tracer.LogSanitizedError(e, $"Failed while updating mwcToken for {iterationId}.");
+                }
+            }
+            else
+            {
+                // When we see a terminal status for this Dag iteration, no need to update the Token in token manager as the execution
+                // is complete and the token can be evicted.
+                if (DagExecutionMetrics.IsInTerminalStatus(status))
+                {
+                    Tracer.LogSanitizedMessage("Dag execution is in a terminal status. Trying to delete the Token in TokenManager");
+                    tokenManager.DeleteCachedToken(artifactId, iterationId);
+                }
+                else
+                {
+                    Tracer.LogSanitizedVerbose("Dag execution is not in a terminal status. Trying to update the Token in TokenManager");
+                    tokenManager.UpdateCachedToken(artifactId, iterationId, mwcToken);
+                }
+            }
+        }
