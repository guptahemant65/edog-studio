+namespace Microsoft.LiveTable.Service.UnitTests.NotebookTests
+{
+    using System;
+    using System.Collections.Concurrent;
+    using System.Diagnostics.CodeAnalysis;
+    using System.Reflection;
+    using Microsoft.LiveTable.Service.Notebook;
+    using Microsoft.VisualStudio.TestTools.UnitTesting;
+
+    /// <summary>
+    /// Unit tests for <see cref="NotebookExecutionContext.GetDqSuiteCommandIndexes"/>.
+    /// Uses reflection to populate the internal dqSuiteCommand dictionary
+    /// without requiring full notebook parsing infrastructure.
+    /// </summary>
+    [ExcludeFromCodeCoverage]
+    [TestClass]
+    [TestCategory("DqTests")]
+    public class DqSuiteCommandTests : IDisposable
+    {
+        private NotebookExecutionContext context;
+
+        /// <summary>
+        /// Sets up a NotebookExecutionContext and populates the dqSuiteCommand
+        /// dictionary via reflection with known test entries.
+        /// </summary>
+        [TestInitialize]
+        public void TestInitialize()
+        {
+            context = new NotebookExecutionContext(Guid.NewGuid(), Guid.NewGuid());
+
+            var field = typeof(NotebookExecutionContext).GetField(
+                "dqSuiteCommand", BindingFlags.NonPublic | BindingFlags.Instance);
+            Assert.IsNotNull(field, "dqSuiteCommand field not found");
+
+            var dict = (ConcurrentDictionary<string, int[]>)field.GetValue(context);
+
+            // Keys are always stored lowercase by the production code
+            dict.TryAdd("dbo.sales", new[] { 0, 2 });
+            dict.TryAdd("schema1.lakehouse1.dbo.orders", new[] { 1, 3 });
+        }
+
+        /// <summary>
+        /// Cleans up after each test.
+        /// </summary>
+        [TestCleanup]
+        public void TestCleanup()
+        {
+            context?.Dispose();
+        }
+
+        /// <summary>
+        /// Exact match returns the expected indexes.
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_ExactMatch_ReturnsIndexes()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes("dbo.sales");
+
+            Assert.IsNotNull(indexes);
+            Assert.AreEqual(2, indexes.Length);
+            Assert.AreEqual(0, indexes[0]);
+            Assert.AreEqual(2, indexes[1]);
+        }
+
+        /// <summary>
+        /// When query is longer than key, suffix matching strips leading segments.
+        /// Query "workspace.lakehouse.dbo.sales" matches key "dbo.sales".
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_QueryLongerThanKey_MatchesBySuffix()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes("workspace.lakehouse.dbo.sales");
+
+            Assert.IsNotNull(indexes);
+            Assert.AreEqual(2, indexes.Length);
+        }
+
+        /// <summary>
+        /// When key is longer than query, suffix matching strips leading segments from the key.
+        /// Query "dbo.orders" matches key "schema1.lakehouse1.dbo.orders".
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_KeyLongerThanQuery_MatchesBySuffix()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes("dbo.orders");
+
+            Assert.IsNotNull(indexes);
+            Assert.AreEqual(2, indexes.Length);
+            Assert.AreEqual(1, indexes[0]);
+            Assert.AreEqual(3, indexes[1]);
+        }
+
+        /// <summary>
+        /// Returns null when no match is found.
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_NoMatch_ReturnsNull()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes("nonexistent.table");
+
+            Assert.IsNull(indexes);
+        }
+
+        /// <summary>
+        /// Returns null when input is null.
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_NullInput_ReturnsNull()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes(null);
+
+            Assert.IsNull(indexes);
+        }
+
+        /// <summary>
+        /// Matching is case-insensitive: "DBO.Sales" matches stored key "dbo.sales".
+        /// </summary>
+        [TestMethod]
+        public void GetDqSuiteCommandIndexes_CaseInsensitive_Matches()
+        {
+            var indexes = context.GetDqSuiteCommandIndexes("DBO.Sales");
+
+            Assert.IsNotNull(indexes);
+            Assert.AreEqual(2, indexes.Length);
+        }
+
+        /// <inheritdoc/>
+        public void Dispose()
+        {
+            Dispose(true);
+            GC.SuppressFinalize(this);
+        }
+
+        /// <summary>
+        /// Releases managed resources.
+        /// </summary>
+        /// <param name="disposing">True if called from Dispose.</param>
+        protected virtual void Dispose(bool disposing)
+        {
+            if (disposing)
+            {
+                context?.Dispose();
+                context = null;
+            }
+        }
+    }
