+        private List<Table> DeserializeDqTestTables(params string[] jsonStrings)
+        {
+            var wsId = Example.GetWorkSpaceId();
+            var lhId = Example.GetArtifactId();
+            var options = new JsonSerializerOptions
+            {
+                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
+                PropertyNameCaseInsensitive = true,
+            };
+
+            var tables = new List<Table>();
+            foreach (var json in jsonStrings)
+            {
+                var table = JsonSerializer.Deserialize<Table>(json, options);
+                table.WorkspaceName = "ws1";
+                table.LakehouseName = "LakehouseName";
+                table.WorkspaceId = wsId;
+                table.LakehouseId = lhId;
+                tables.Add(table);
+            }
+
+            return tables;
+        }
