+        /// <summary>
+        /// Get Notebook Content indexes to execute for the DQ suite associated with the given MLV.
+        /// Matching strategy (in order):
+        ///   1. Exact match on lowered name.
+        ///   2. Strip leading segments from the query name (handles query longer than key,
+        ///      e.g., query "workspace.lakehouse.dbo.table" matches key "dbo.table").
+        ///   3. Strip leading segments from each dictionary key (handles key longer than query,
+        ///      e.g., query "dbo.table" matches key "workspace.lakehouse.dbo.table").
+        /// </summary>
+        /// <param name="mlvName">MLV name (may be fully-qualified or partial).</param>
+        /// <returns>Notebook Content indexes for the DQ suite cell, or null if not found.</returns>
+        public virtual int[] GetDqSuiteCommandIndexes(string mlvName)
+        {
+            ThrowIfDisposed();
+            if (string.IsNullOrWhiteSpace(mlvName))
+            {
+                return null;
+            }
+
+            string lowerName = mlvName.ToLowerInvariant();
+
+            // Strategy 1: exact match (e.g., "dbo.empty_mlv")
+            if (dqSuiteCommand.TryGetValue(lowerName, out int[] indexes))
+            {
+                return indexes;
+            }
+
+            // Strategy 2: strip leading segments from the query name.
+            // Handles: query is longer than key (e.g., query "workspace.lakehouse.dbo.table" → key "dbo.table").
+            string remaining = lowerName;
+            while (true)
+            {
+                int dotIndex = remaining.IndexOf('.');
+                if (dotIndex < 0 || dotIndex >= remaining.Length - 1)
+                {
+                    break;
+                }
+
+                remaining = remaining.Substring(dotIndex + 1);
+                if (dqSuiteCommand.TryGetValue(remaining, out indexes))
+                {
+                    Tracer.LogSanitizedMessage($"DQ suite matched '{mlvName}' using query-suffix '{remaining}'");
+                    return indexes;
+                }
+            }
+
+            // Strategy 3: strip leading segments from each dictionary key.
+            // Handles: key is longer than query (e.g., query "dbo.table" → key "workspace.lakehouse.dbo.table").
+            // Use longest matching key for determinism (most-specific match wins).
+            string bestKey = null;
+            int[] bestIndexes = null;
+            int matchCount = 0;
+
+            foreach (var kvp in dqSuiteCommand)
+            {
+                string keySuffix = kvp.Key;
+                while (true)
+                {
+                    int dotIndex = keySuffix.IndexOf('.');
+                    if (dotIndex < 0 || dotIndex >= keySuffix.Length - 1)
+                    {
+                        break;
+                    }
+
+                    keySuffix = keySuffix.Substring(dotIndex + 1);
+                    if (keySuffix.Equals(lowerName, StringComparison.Ordinal))
+                    {
+                        matchCount++;
+                        if (bestKey == null || kvp.Key.Length > bestKey.Length)
+                        {
+                            bestKey = kvp.Key;
+                            bestIndexes = kvp.Value;
+                        }
+
+                        break;
+                    }
+                }
+            }
+
+            if (bestIndexes != null)
+            {
+                if (matchCount > 1)
+                {
+                    Tracer.LogSanitizedWarning($"DQ suite found {matchCount} ambiguous suffix matches for '{mlvName}'. Using longest key '{bestKey}' for deterministic selection.");
+                }
+
+                Tracer.LogSanitizedMessage($"DQ suite matched '{mlvName}' using key-suffix from key '{bestKey}'");
+                return bestIndexes;
+            }
+
+            // No match found — log available keys for diagnostics
+            var availableKeys = dqSuiteCommand.Keys.ToArray();
+            Tracer.LogSanitizedWarning($"GetDqSuiteCommandIndexes: no match for '{mlvName}' (lowered: '{lowerName}'). Dictionary has {availableKeys.Length} key(s): [{string.Join(", ", availableKeys)}]");
+            return null;
+        }
