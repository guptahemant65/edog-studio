+        /// </summary>
+        /// <param name="current">The current period value.</param>
+        /// <param name="previous">The previous period value.</param>
+        /// <returns>Percentage change, or 100 if previous is zero with positive current, or null if both are zero.</returns>
+        internal static double? ComputeDeltaPct(double current, double previous)
+        {
+            if (previous == 0)
+            {
+                return current > 0 ? 100.0 : null;
+            }
+
+            return Math.Round(((current - previous) / previous) * 100, 1);
