+// </copyright>
+
+namespace Microsoft.LiveTable.Service.Trends.Models
+{
+    using Newtonsoft.Json;
+
+    /// <summary>
+    /// Fractional refresh policy distribution across DAG runs.
+    /// Each run contributes exactly 1.0, split proportionally by per-node effective refresh policy.
+    /// The sum of all three fields equals the number of runs with at least one refresh-eligible node.
+    /// </summary>
+    public class RefreshPolicyDistribution
+    {
+        /// <summary>Gets or sets the sum of full-refresh fractions across runs.</summary>
+        [JsonProperty("full")]
+        public double Full { get; set; }
+
+        /// <summary>Gets or sets the sum of incremental-refresh fractions across runs.</summary>
+        [JsonProperty("incremental")]
+        public double Incremental { get; set; }
+
+        /// <summary>Gets or sets the sum of no-refresh fractions across runs.</summary>
+        [JsonProperty("noRefresh")]
+        public double NoRefresh { get; set; }
+    }
+}
