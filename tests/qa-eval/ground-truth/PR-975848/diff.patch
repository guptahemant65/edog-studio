+        /// <summary>
+        /// Maps a <see cref="DbDataReader"/> positioned before the first row to an <see cref="InsightsSummaryResponse"/>.
+        /// Extracted from <see cref="GetSummaryAsync"/> for testability — the reader is provided by a real SQL connection
+        /// in production but can be mocked via <see cref="DbDataReader"/> in unit tests.
+        /// </summary>
+        /// <param name="reader">The data reader to read from.</param>
+        /// <param name="cancellationToken">Cancellation token.</param>
+        /// <returns>A populated <see cref="InsightsSummaryResponse"/>.</returns>
+        internal static async Task<InsightsSummaryResponse> MapSummaryResponseAsync(DbDataReader reader, CancellationToken cancellationToken)
+        {
+            var response = new InsightsSummaryResponse();
+
+            if (await reader.ReadAsync(cancellationToken))
+            {
+                response.TotalRuns = await reader.IsDBNullAsync(reader.GetOrdinal("totalRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("totalRuns"));
+                response.FailedRuns = await reader.IsDBNullAsync(reader.GetOrdinal("failedRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("failedRuns"));
+                response.SkippedRuns = await reader.IsDBNullAsync(reader.GetOrdinal("skippedRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("skippedRuns"));
+                response.CancelledRuns = await reader.IsDBNullAsync(reader.GetOrdinal("cancelledRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("cancelledRuns"));
+
+                int completedRuns = await reader.IsDBNullAsync(reader.GetOrdinal("completedRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("completedRuns"));
+                double avgDurMs = await reader.IsDBNullAsync(reader.GetOrdinal("avgDurationMs"), cancellationToken) ? 0 : reader.GetDouble(reader.GetOrdinal("avgDurationMs"));
+
+                int lastUpdatedAtOrdinal = reader.GetOrdinal("lastUpdatedAt");
+                string lastUpdatedAtStr = await reader.IsDBNullAsync(lastUpdatedAtOrdinal, cancellationToken)
+                    ? null
+                    : reader.GetString(lastUpdatedAtOrdinal);
+
+                response.CompletedRuns = completedRuns;
+                response.SuccessRatePct = response.TotalRuns > 0
+                    ? Math.Round((double)completedRuns / response.TotalRuns * 100, 1)
+                    : 0;
+                response.AvgDurationMin = Math.Round(avgDurMs / 60000.0, 1);
+                response.LastUpdatedAt = DateTime.TryParse(lastUpdatedAtStr, out var lua) ? lua : null;
+
+                // Refresh policy distribution (fractional model)
+                response.RefreshPolicyDistribution = new Models.RefreshPolicyDistribution
+                {
+                    Full = await reader.IsDBNullAsync(reader.GetOrdinal("fractionFullSum"), cancellationToken) ? 0 : Math.Round(reader.GetDouble(reader.GetOrdinal("fractionFullSum")), 1),
+                    Incremental = await reader.IsDBNullAsync(reader.GetOrdinal("fractionIncrementalSum"), cancellationToken) ? 0 : Math.Round(reader.GetDouble(reader.GetOrdinal("fractionIncrementalSum")), 1),
+                    NoRefresh = await reader.IsDBNullAsync(reader.GetOrdinal("fractionNoRefreshSum"), cancellationToken) ? 0 : Math.Round(reader.GetDouble(reader.GetOrdinal("fractionNoRefreshSum")), 1),
+                };
+
+                // Previous period values for delta computation
+                int prevTotalRuns = await reader.IsDBNullAsync(reader.GetOrdinal("prevTotalRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("prevTotalRuns"));
+                int prevCompletedRuns = await reader.IsDBNullAsync(reader.GetOrdinal("prevCompletedRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("prevCompletedRuns"));
+                int prevFailedRuns = await reader.IsDBNullAsync(reader.GetOrdinal("prevFailedRuns"), cancellationToken) ? 0 : reader.GetInt32(reader.GetOrdinal("prevFailedRuns"));
+                double prevAvgDurMs = await reader.IsDBNullAsync(reader.GetOrdinal("prevAvgDurationMs"), cancellationToken) ? 0 : reader.GetDouble(reader.GetOrdinal("prevAvgDurationMs"));
+
+                // Compute deltas only when previous period has data
+                if (prevTotalRuns > 0)
+                {
+                    response.TotalRunsDeltaPct = ComputeDeltaPct(response.TotalRuns, prevTotalRuns);
+
+                    double prevSuccessRate = Math.Round((double)prevCompletedRuns / prevTotalRuns * 100, 1);
+                    response.SuccessRateDeltaPct = Math.Round(response.SuccessRatePct - prevSuccessRate, 1);
+
+                    response.FailedRunsDeltaPct = ComputeDeltaPct(response.FailedRuns, prevFailedRuns);
+
+                    double prevAvgDurMin = Math.Round(prevAvgDurMs / 60000.0, 1);
+                    response.AvgDurationDeltaPct = prevAvgDurMin > 0
+                        ? ComputeDeltaPct(response.AvgDurationMin, prevAvgDurMin)
+                        : null;
+                }
+            }
