+        /// <inheritdoc/>
+        public async Task<(List<string> Paths, string ContinuationToken)> ListWithContinuationAsync(
+            string path,
+            int maxCount = default,
+            string continuationToken = null,
+            CancellationToken cancellationToken = default)
+        {
+            if (ListingFilesShouldThrowException)
+            {
+                throw new Exception("Simulated failure in listing files");
+            }
+
+            // Default to 5000 if not specified (aligned with OneLake/Lakehouse defaults)
+            const int DefaultMaxResults = 5000;
+            int effectiveMaxCount = maxCount <= 0 ? DefaultMaxResults : maxCount;
+
+            // For in-memory stub, we simulate pagination by using continuationToken as a skip index
+            int skipCount = 0;
+            if (!string.IsNullOrEmpty(continuationToken) && int.TryParse(continuationToken, out int parsedSkip))
+            {
+                skipCount = parsedSkip;
+            }
+
+            // Get the full list using existing ListAsync logic
+            var allFiles = await ListAsync(path, -1, cancellationToken);
+
+            // Apply pagination
+            var paginatedFiles = allFiles.Skip(skipCount).Take(effectiveMaxCount).ToList();
+
+            // Generate next continuation token if there are more items
+            string nextContinuationToken = null;
+            if (skipCount + effectiveMaxCount < allFiles.Count)
+            {
+                nextContinuationToken = (skipCount + effectiveMaxCount).ToString();
+            }
+
+            return (paginatedFiles, nextContinuationToken);
+        }
