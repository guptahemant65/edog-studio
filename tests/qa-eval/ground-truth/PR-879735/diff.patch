+                // Decode Base64Url
+                byte[] bytes = WebEncoders.Base64UrlDecode(token);
+                string rawToken = Encoding.UTF8.GetString(bytes);
+
+                // Parse: {reverseEpoch}_{iterationId}_{filterHash}
+                string[] parts = rawToken.Split(Separator);
