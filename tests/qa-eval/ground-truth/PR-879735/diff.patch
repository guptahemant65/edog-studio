+                {
+                    return false;
+                }
+
+                if (!long.TryParse(parts[0], out reverseEpoch))
+                {
+                    return false;
+                }
+
+                if (!Guid.TryParse(parts[1], out iterationId))
+                {
+                    return false;
+                }
+
+                // Extract filter hash
+                filterHash = parts[2];
+
+                return true;
+            }
