+        /// <inheritdoc/>
+        public Task<(List<string> Paths, string ContinuationToken)> ListWithContinuationAsync(
+            string path,
+            int maxCount = default,
+            string continuationToken = null,
+            CancellationToken cancellationToken = default)
+        {
+            if (ThrowError)
+            {
+                throw new ServiceException();
+            }
+
+            // Simple implementation: use existing ListAsync logic
+            var allFiles = Files.Keys.ToList();
+            int effectiveMaxCount = maxCount <= 0 ? 5000 : maxCount;
+
+            // Simulate pagination with skip index
+            int skipCount = 0;
+            if (!string.IsNullOrEmpty(continuationToken) && int.TryParse(continuationToken, out int parsedSkip))
+            {
+                skipCount = parsedSkip;
+            }
+
+            var paginatedFiles = allFiles.Skip(skipCount).Take(effectiveMaxCount).ToList();
+            string nextContinuationToken = null;
+            if (skipCount + effectiveMaxCount < allFiles.Count)
+            {
+                nextContinuationToken = (skipCount + effectiveMaxCount).ToString();
+            }
+
+            return Task.FromResult((paginatedFiles, nextContinuationToken));
+        }
     }
