+
+            // Statuses - sorted for determinism
+            if (filters.Statuses?.Count > 0)
+            {
+                sb.Append(string.Join(",", filters.Statuses.OrderBy(s => s.ToString())));
+            }
+
+            sb.Append('|');
+
+            // StartTime - epoch seconds
+            if (filters.StartTime.HasValue)
+            {
+                sb.Append(new DateTimeOffset(filters.StartTime.Value.ToUniversalTime()).ToUnixTimeSeconds());
+            }
+
+            sb.Append('|');
+
+            // EndTime - epoch seconds
+            if (filters.EndTime.HasValue)
+            {
+                sb.Append(new DateTimeOffset(filters.EndTime.Value.ToUniversalTime()).ToUnixTimeSeconds());
+            }
+
+            sb.Append('|');
+
+            // MlvExecutionDefinitionIds - sorted for determinism
+            if (filters.MlvExecutionDefinitionIds?.Count > 0)
+            {
+                sb.Append(string.Join(",", filters.MlvExecutionDefinitionIds.OrderBy(g => g).Select(g => g.ToString().ToLowerInvariant())));
+            }
+
+            return ComputeHashFromString(sb.ToString());
+        }
+
+        /// <summary>
+        /// Validates if the filter hash in the token matches the current filters.
+        /// </summary>
+        /// <param name="tokenFilterHash">The filter hash from the continuation token.</param>
+        /// <param name="currentFilters">The current request filters.</param>
+        /// <returns>True if hashes match (or token has no hash), false otherwise.</returns>
+        public static bool ValidateFilterHash(string tokenFilterHash, ListDagExecutionIterationsRequestFilters currentFilters)
+        {
+            // Tokens with empty filter hash skip validation (filter checking disabled)
+            if (string.IsNullOrEmpty(tokenFilterHash))
+            {
+                return true;
+            }
+
+            string currentHash = ComputeFilterHash(currentFilters);
+            return string.Equals(tokenFilterHash, currentHash, StringComparison.OrdinalIgnoreCase);
+        }
+
+        /// <summary>
+        /// Converts reverse epoch back to DateTime (UTC).
+        /// </summary>
+        /// <param name="reverseEpoch">The reverse epoch value.</param>
+        /// <returns>The UTC DateTime corresponding to the reverse epoch.</returns>
+        public static DateTime ReverseEpochToDateTime(long reverseEpoch)
+        {
+            long epochSeconds = long.MaxValue - reverseEpoch;
+            return DateTimeOffset.FromUnixTimeSeconds(epochSeconds).UtcDateTime;
+        }
+
+        /// <summary>
+        /// Converts DateTime to reverse epoch (for cursor comparison).
+        /// </summary>
+        /// <param name="dateTime">The DateTime to convert.</param>
+        /// <returns>The reverse epoch value.</returns>
+        public static long DateTimeToReverseEpoch(DateTime dateTime)
+        {
+            long epochSeconds = new DateTimeOffset(dateTime.ToUniversalTime()).ToUnixTimeSeconds();
+            return long.MaxValue - epochSeconds;
+        }
+
+        /// <summary>
+        /// Validates if a token is well-formed without full decode.
+        /// </summary>
+        /// <param name="token">The token to validate.</param>
+        /// <returns>True if the token is valid, false otherwise.</returns>
+        public static bool IsValid(string token)
+        {
+            return TryDecode(token, out _, out _, out _);
+        }
+
+        /// <summary>
+        /// Computes SHA256 hash and returns first 8 characters as hex.
+        /// </summary>
+        private static string ComputeHashFromString(string input)
+        {
+            byte[] inputBytes = Encoding.UTF8.GetBytes(input);
+            byte[] hashBytes = SHA256.HashData(inputBytes);
+            return Convert.ToHexString(hashBytes).Substring(0, FilterHashLength).ToLowerInvariant();
+        }
+    }
+}
