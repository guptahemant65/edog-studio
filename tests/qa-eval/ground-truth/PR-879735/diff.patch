+        /// Encodes pagination cursor into a continuation token.
+        /// </summary>
+        /// <param name="startedAt">The StartedAt timestamp of the last item.</param>
+        /// <param name="iterationId">The IterationId of the last item.</param>
+        /// <param name="filterHash">The hash of current filter parameters.</param>
+        /// <returns>Base64Url-encoded continuation token.</returns>
+        public static string Encode(DateTime startedAt, Guid iterationId, string filterHash)
+        {
+            // Convert to reverse epoch (same format as index file names)
+            long reverseEpoch = DateTimeToReverseEpoch(startedAt);
+
+            // Build raw token: {reverseEpoch}_{iterationId}_{filterHash}
+            string rawToken = string.Join(Separator.ToString(), reverseEpoch, iterationId, filterHash ?? string.Empty);
+
+            // Base64Url encode for URL safety (no +, /, = characters)
+            return WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(rawToken));
+        }
