+        /// Attempts to decode a continuation token.
+        /// </summary>
+        /// <param name="token">The Base64Url-encoded continuation token.</param>
+        /// <param name="reverseEpoch">Output: The reverse epoch ticks.</param>
+        /// <param name="iterationId">Output: The iteration ID.</param>
+        /// <param name="filterHash">Output: The filter hash.</param>
+        /// <returns>True if decoding succeeded, false otherwise.</returns>
+        public static bool TryDecode(
+            string token,
+            out long reverseEpoch,
+            out Guid iterationId,
+            out string filterHash)
