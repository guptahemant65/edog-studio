+namespace Microsoft.LiveTable.Service.UnitTests.UtilsTests
+{
+    using System;
+    using System.Collections.Generic;
+    using System.Linq;
+    using Microsoft.AspNetCore.WebUtilities;
+    using Microsoft.LiveTable.Service.DataModel;
+    using Microsoft.LiveTable.Service.DataModel.Dag;
+    using Microsoft.LiveTable.Service.Utils;
+    using Microsoft.VisualStudio.TestTools.UnitTesting;
+
+    /// <summary>
+    /// Unit tests for <see cref="ContinuationTokenHelper"/>.
+    /// </summary>
+    [TestClass]
+    public class ContinuationTokenHelperTests
+    {
+        private const string TestFilterHash = "abc12345";
+
+        [TestMethod]
+        public void Encode_ValidInputs_ReturnsBase64Token()
+        {
+            // Arrange
+            var startedAt = new DateTime(2024, 1, 15, 10, 30, 0, DateTimeKind.Utc);
+            var iterationId = Guid.Parse("a1b2c3d4-e5f6-7890-abcd-ef1234567890");
+
+            // Act
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, TestFilterHash);
+
+            // Assert
+            Assert.IsNotNull(token);
+            Assert.IsFalse(string.IsNullOrWhiteSpace(token));
+
+            // Verify it's valid Base64Url
+            var bytes = WebEncoders.Base64UrlDecode(token);
+            Assert.IsTrue(bytes.Length > 0);
+        }
+
+        [TestMethod]
+        public void Encode_MinDateTime_HandlesCorrectly()
+        {
+            // Arrange
+            var startedAt = DateTime.MinValue.ToUniversalTime();
+            var iterationId = Guid.NewGuid();
+
+            // Act
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, TestFilterHash);
+
+            // Assert
+            Assert.IsNotNull(token);
+            Assert.IsTrue(ContinuationTokenHelper.IsValid(token));
+        }
+
+        [TestMethod]
+        public void Encode_MaxDateTime_HandlesCorrectly()
+        {
+            // Arrange - use a date far in the future but not DateTime.MaxValue to avoid overflow
+            var startedAt = new DateTime(3000, 12, 31, 23, 59, 59, DateTimeKind.Utc);
+            var iterationId = Guid.NewGuid();
+
+            // Act
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, TestFilterHash);
+
+            // Assert
+            Assert.IsNotNull(token);
+            Assert.IsTrue(ContinuationTokenHelper.IsValid(token));
+        }
+
+        [TestMethod]
+        public void Encode_EmptyGuid_EncodesCorrectly()
+        {
+            // Arrange
+            var startedAt = DateTime.UtcNow;
+            var iterationId = Guid.Empty;
+
+            // Act
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, TestFilterHash);
+
+            // Assert
+            Assert.IsNotNull(token);
+            Assert.IsTrue(ContinuationTokenHelper.TryDecode(token, out _, out var decodedId, out _));
+            Assert.AreEqual(Guid.Empty, decodedId);
+        }
+
+        [TestMethod]
+        public void Encode_NullFilterHash_EncodesCorrectly()
+        {
+            // Arrange
+            var startedAt = DateTime.UtcNow;
+            var iterationId = Guid.NewGuid();
+
+            // Act
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, null);
+
+            // Assert
+            Assert.IsNotNull(token);
+            Assert.IsTrue(ContinuationTokenHelper.TryDecode(token, out _, out _, out var filterHash));
+            Assert.AreEqual(string.Empty, filterHash);
+        }
+
+        [TestMethod]
+        public void TryDecode_ValidToken_ReturnsTrue()
+        {
+            // Arrange
+            var startedAt = new DateTime(2024, 1, 15, 10, 30, 0, DateTimeKind.Utc);
+            var iterationId = Guid.Parse("a1b2c3d4-e5f6-7890-abcd-ef1234567890");
+            var token = ContinuationTokenHelper.Encode(startedAt, iterationId, TestFilterHash);
+
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(token, out var reverseEpoch, out var decodedId, out var decodedFilterHash);
+
+            // Assert
+            Assert.IsTrue(result);
+            Assert.AreEqual(iterationId, decodedId);
+            Assert.AreEqual(TestFilterHash, decodedFilterHash);
+            Assert.IsTrue(reverseEpoch > 0);
+        }
+
+        [TestMethod]
+        public void TryDecode_NullToken_ReturnsFalse()
+        {
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(null, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_EmptyToken_ReturnsFalse()
+        {
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(string.Empty, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_WhitespaceToken_ReturnsFalse()
+        {
+            // Act
+            var result = ContinuationTokenHelper.TryDecode("   ", out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_InvalidBase64_ReturnsFalse()
+        {
+            // Act
+            var result = ContinuationTokenHelper.TryDecode("not-valid-base64!!!", out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_WrongPartCount_TwoParts_ReturnsFalse()
+        {
+            // Arrange - encode a token with only 2 parts
+            var invalidRaw = "12345_a1b2c3d4-e5f6-7890-abcd-ef1234567890";
+            var invalidToken = WebEncoders.Base64UrlEncode(System.Text.Encoding.UTF8.GetBytes(invalidRaw));
+
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(invalidToken, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_WrongPartCount_FiveParts_ReturnsFalse()
+        {
+            // Arrange - encode a token with 4 parts (wrong for 3-part format)
+            var invalidRaw = "12345_a1b2c3d4-e5f6-7890-abcd-ef1234567890_hash_extra";
+            var invalidToken = WebEncoders.Base64UrlEncode(System.Text.Encoding.UTF8.GetBytes(invalidRaw));
+
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(invalidToken, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_InvalidReverseEpoch_ReturnsFalse()
+        {
+            // Arrange - non-numeric reverse epoch
+            var invalidRaw = "notanumber_a1b2c3d4-e5f6-7890-abcd-ef1234567890_abc12345";
+            var invalidToken = WebEncoders.Base64UrlEncode(System.Text.Encoding.UTF8.GetBytes(invalidRaw));
+
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(invalidToken, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_InvalidGuid_ReturnsFalse()
+        {
+            // Arrange - invalid GUID format
+            var invalidRaw = "12345_not-a-valid-guid_abc12345";
+            var invalidToken = WebEncoders.Base64UrlEncode(System.Text.Encoding.UTF8.GetBytes(invalidRaw));
+
+            // Act
+            var result = ContinuationTokenHelper.TryDecode(invalidToken, out _, out _, out _);
+
+            // Assert
+            Assert.IsFalse(result);
+        }
+
+        [TestMethod]
+        public void TryDecode_TamperedToken_ReturnsFalse()
+        {
