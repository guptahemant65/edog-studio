+    /// <summary>
+    /// Helper class for encoding and decoding pagination continuation tokens.
+    /// Token format: {reverseEpochTicks}_{iterationId}_{filterHash} (Base64Url encoded)
+    /// </summary>
+    /// <remarks>
+    /// The token encodes the cursor position of the last item returned in the current page.
+    /// - reverseEpochTicks: Position in time-sorted order (larger = older), matches index file naming convention
