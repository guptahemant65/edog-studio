+        /// <summary>
+        /// Maps the current row of a positioned <see cref="DbDataReader"/> to a <see cref="DailyTrendEntry"/>.
+        /// Uses <see cref="DbDataReader"/> (abstract base of <see cref="SqlDataReader"/>) so the mapping
+        /// can be unit-tested with a mocked reader — same pattern as <see cref="MapSummaryResponseAsync"/>.
+        /// Fraction values are <see cref="Math.Round(double, int)"/>-rounded to 1 decimal to match the
+        /// summary endpoint's <see cref="RefreshPolicyDistribution"/> precision.
+        /// </summary>
+        /// <param name="reader">A <see cref="DbDataReader"/> positioned on the row to map.</param>
+        /// <param name="cancellationToken">Cancellation token.</param>
+        /// <returns>A populated <see cref="DailyTrendEntry"/>.</returns>
+        internal static async Task<DailyTrendEntry> MapTrendEntryAsync(DbDataReader reader, CancellationToken cancellationToken)
+        {
+            int runDateOrd = reader.GetOrdinal("run_date");
+            string runDate = await reader.IsDBNullAsync(runDateOrd, cancellationToken)
+                ? null
+                : reader.GetString(runDateOrd);
+
+            int fractionFullOrd = reader.GetOrdinal("fractionFull");
+            int fractionIncOrd = reader.GetOrdinal("fractionIncremental");
+            int fractionNrOrd = reader.GetOrdinal("fractionNoRefresh");
+
+            return new DailyTrendEntry
+            {
+                RunDate = runDate,
+                Completed = reader.GetInt32(reader.GetOrdinal("completed")),
+                Failed = reader.GetInt32(reader.GetOrdinal("failed")),
+                Skipped = reader.GetInt32(reader.GetOrdinal("skipped")),
+                Cancelled = reader.GetInt32(reader.GetOrdinal("cancelled")),
+                RefreshPolicyDistribution = new RefreshPolicyDistribution
+                {
+                    Full = await reader.IsDBNullAsync(fractionFullOrd, cancellationToken)
+                        ? 0
+                        : Math.Round(reader.GetDouble(fractionFullOrd), 1),
+                    Incremental = await reader.IsDBNullAsync(fractionIncOrd, cancellationToken)
+                        ? 0
+                        : Math.Round(reader.GetDouble(fractionIncOrd), 1),
+                    NoRefresh = await reader.IsDBNullAsync(fractionNrOrd, cancellationToken)
+                        ? 0
+                        : Math.Round(reader.GetDouble(fractionNrOrd), 1),
+                },
+            };
+        }
+
