{
  "$schema": "https://example.invalid/edog-blocklist.schema.json",
  "version": 3,
  "comment": "Components matching ANY regex are dropped at the EDOG source. Patterns are tested against the raw CodeMarkerName (case-insensitive). Errors and Warnings always bypass this list. To tune, edit and re-run 'edog --deploy'.",
  "blocked": [
    {
      "pattern": "^Microsoft\\.AspNetCore",
      "reason": "ASP.NET Core HTTP pipeline internals"
    },
    {
      "pattern": "^Microsoft\\.Extensions",
      "reason": ".NET generic host / DI / configuration noise"
    },
    {
      "pattern": "^Microsoft\\.EntityFrameworkCore",
      "reason": "EF Core internals"
    },
    {
      "pattern": "^System\\.",
      "reason": ".NET base class library traces"
    },
    {
      "pattern": "^Kestrel",
      "reason": "Kestrel HTTP server framing / connection noise"
    },
    {
      "pattern": "^ServicePlatform",
      "reason": "Service Platform internal traces"
    },
    {
      "pattern": "^IntervalTimer",
      "reason": "Platform interval timer ticks (HiccupMonitor, etc.)"
    },
    {
      "pattern": "MetricsAccumulator",
      "reason": "WCL resource/consumption metrics accumulators — high-frequency timer noise"
    },
    {
      "pattern": "^ReportUsageMetrics",
      "reason": "Usage metrics reporting timer"
    },
    {
      "pattern": "^WorkloadInitialization",
      "reason": "Workload health check / relay probe pings"
    },
    {
      "pattern": "^WorkloadResourceMetrics",
      "reason": "Workload resource metrics polling"
    },
    {
      "pattern": "^WCL-PlatformRelay",
      "reason": "Platform relay internal messaging"
    },
    {
      "pattern": "^WCL-Health",
      "reason": "WCL health probe internals"
    },
    {
      "pattern": "^WCL-Startup",
      "reason": "WCL startup/bootstrap noise"
    },
    {
      "pattern": "^WCL-Security",
      "reason": "WCL security/auth pipeline noise"
    },
    {
      "pattern": "^WCL-Middleware",
      "reason": "WCL middleware pipeline noise"
    },
    {
      "pattern": "^Trident",
      "reason": "Trident platform internals"
    },
    {
      "pattern": "^FeatureManagement",
      "reason": ".NET feature management framework"
    },
    {
      "pattern": "^Azure\\.",
      "reason": "Azure SDK client library internals"
    }
  ]
}
